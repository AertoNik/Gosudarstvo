      function renderRegionSvg(region) {
        const centroid = getCentroid(region.points);
        const selected = region.id === selectedRegionId ? "selected" : "";
        return `
          <g>
            <polygon class="region-poly ${selected}" data-action="select-region" data-id="${region.id}" points="${pointsAttr(region.points)}" fill="${esc(region.color)}" opacity=".82"></polygon>
            ${renderRegionRoads(region)}
            ${renderBuildingMarkers(region, centroid)}
            <text class="map-label" x="${centroid.x}" y="${centroid.y}" text-anchor="middle">${esc(region.name)}</text>
          </g>
        `;
      }

      function renderRegionRoads(region) {
        const pts = region.points;
        const c = getCentroid(pts);
        let roads = "";
        for (let i = 0; i < Math.min(region.buildings.roads, pts.length); i++) {
          const p = pts[i % pts.length];
          roads += `<line x1="${c.x}" y1="${c.y}" x2="${p[0]}" y2="${p[1]}" stroke="rgba(255,255,255,.72)" stroke-width="4" stroke-linecap="round"></line>`;
        }
        return roads;
      }

      function renderBuildingMarkers(region, centroid) {
        const markers = [];
        const icons = { cities:"●", airports:"✈", ports:"⚓", bases:"▲", plants:"◆", factories:"■", schools:"S", hospitals:"+", universities:"U", farms:"F", mines:"M", oil:"O", gas:"G" };
        let idx = 0;
        for (const [key] of buildingTypes) {
          const count = region.buildings[key] || 0;
          for (let i = 0; i < Math.min(count, key === "roads" ? 0 : 3); i++) {
            const angle = (idx++ / 16) * Math.PI * 2;
            const x = centroid.x + Math.cos(angle) * (26 + (idx % 3) * 18);
            const y = centroid.y + Math.sin(angle) * (20 + (idx % 4) * 14);
            markers.push(`<g class="build-marker"><circle cx="${x}" cy="${y}" r="11" fill="rgba(5,10,18,.78)" stroke="white" stroke-width="1.5"></circle><text x="${x}" y="${y + 4}" text-anchor="middle" fill="white" font-size="11" font-weight="900">${icons[key] || "•"}</text></g>`);
          }
        }
        return markers.join("");
      }

      function renderDrawingSvg() {
        const points = drawingPoints.map(p => `<circle class="draw-point" cx="${p[0]}" cy="${p[1]}" r="6"></circle>`).join("");
        const line = drawingPoints.length > 1 ? `<polyline points="${pointsAttr(drawingPoints)}" fill="rgba(255,191,71,.18)" stroke="var(--warn)" stroke-width="3" stroke-dasharray="7 6"></polyline>` : "";
        return `<g>${line}${points}</g>`;
      }

      function pointsAttr(points) {
        return points.map(p => `${Number(p[0]).toFixed(1)},${Number(p[1]).toFixed(1)}`).join(" ");
      }

      function getCentroid(points) {
        const sum = points.reduce((a, p) => ({ x: a.x + p[0], y: a.y + p[1] }), { x: 0, y: 0 });
        return { x: sum.x / points.length, y: sum.y / points.length };
      }

