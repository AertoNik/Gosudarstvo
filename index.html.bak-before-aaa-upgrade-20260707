      function drawChart(canvas, data, label) {
        const rect = canvas.getBoundingClientRect();
        const ratio = window.devicePixelRatio || 1;
        canvas.width = Math.max(320, Math.floor(rect.width * ratio));
        canvas.height = Math.max(180, Math.floor(rect.height * ratio));
        const ctx = canvas.getContext("2d");
        ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
        const w = rect.width;
        const h = rect.height;
        ctx.clearRect(0, 0, w, h);
        const styles = getComputedStyle(document.body);
        const text = styles.getPropertyValue("--text").trim();
        const muted = styles.getPropertyValue("--muted").trim();
        const accent = styles.getPropertyValue("--accent").trim();
        const accent2 = styles.getPropertyValue("--accent-2").trim();
        ctx.fillStyle = muted;
        ctx.font = "12px Inter, sans-serif";
        ctx.fillText(label, 12, 18);
        const values = data.length ? data : [0];
        const min = Math.min(...values);
        const max = Math.max(...values);
        const span = Math.max(1, max - min);
        const pad = 28;
        ctx.strokeStyle = "rgba(148, 163, 184, .18)";
        ctx.lineWidth = 1;
        for (let i = 0; i < 5; i++) {
          const y = pad + (i / 4) * (h - pad * 1.7);
          ctx.beginPath();
          ctx.moveTo(10, y);
          ctx.lineTo(w - 10, y);
          ctx.stroke();
        }
        const grad = ctx.createLinearGradient(0, 0, w, 0);
        grad.addColorStop(0, accent);
        grad.addColorStop(1, accent2);
        ctx.strokeStyle = grad;
        ctx.lineWidth = 3;
        ctx.beginPath();
        values.forEach((v, i) => {
          const x = 14 + (i / Math.max(1, values.length - 1)) * (w - 28);
          const y = h - pad - ((v - min) / span) * (h - pad * 2);
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        });
        ctx.stroke();
        ctx.fillStyle = text;
        ctx.font = "700 13px Inter, sans-serif";
        ctx.fillText(String(values[values.length - 1] ?? 0), 12, h - 10);
        ctx.fillStyle = muted;
        ctx.fillText(`min ${min.toFixed(1)} · max ${max.toFixed(1)}`, Math.max(12, w - 190), h - 10);
      }

