          policeName: config.policeName || "Федеральная полиция",
          courtName: config.courtName || "Верховный конституционный суд",
          ministries: (config.ministries || "Экономики, Обороны, Иностранных дел, Здравоохранения, Образования, Транспорта, Энергетики").split(",").map(s => s.trim()).filter(Boolean),
          language: config.language || "аврорский",
          people: config.people || "аврорцы",
          citizenship: config.citizenship || "гражданин Авроры",
          partiesText: config.parties || "Партия обновления, Гражданская платформа, Союз труда, Национальный блок",
          religionsText: config.religions || "Светские, Традиционная вера, Другие конфессии",
          nationalHoliday: config.nationalHoliday || "День Республики",
          anthem: config.anthem || "Гимн свободных городов",
          coat: config.coat || "Серебряная звезда над волной",
          flagName: config.flagName || "Три горизонта",
          continent: config.continent || "Евразия",
          neighbors: (config.neighbors || "Финляндия, Казахстан, Турция").split(",").map(s => s.trim()).filter(Boolean),
          flag: { colors: [config.flagA || "#21c7a8", config.flagB || "#f8fafc", config.flagC || "#4fa3ff"], layout: config.flagLayout || "horizontal" },
          president: {
            name: config.presidentName || "Александр Рей",
            gender: config.gender || "не указан",
            age: num(config.age, 46),
            bio: config.bio || "Реформатор, бывший губернатор столичного региона и автор программы технологического суверенитета.",
            party: config.party || "Партия обновления",
            ideology: config.ideology || "центризм",
            photo: config.photo || ""
          }
        };
        const economy = defaultEconomy();
        const politics = defaultPolitics({ party: country.president.party, ideology: country.president.ideology, opposition: "Гражданская платформа" });
        const population = defaultPopulation(populationTotal);
        const diplomacy = { countries: createWorldCountries(country.neighbors), organizations: defaultOrganizations() };
        const game = {
          version: 4,
          createdAt: new Date().toISOString(),
          lastSaved: new Date().toISOString(),
          theme: "dark",
          speed: 0,
          date: { day: 1, month: 1, year: 2028 },
          country,
          regions,
          economy,
          politics,
          diplomacy,
          military: defaultMilitary(),
          tech: createTech(),
          population,
          news: [],
          history: emptyHistory()
        };
        selectedRegionId = regions[0]?.id || null;
        selectedCountryId = diplomacy.countries[0]?.id || null;
        pushNews(game, "Политика", "Инаугурация", `${country.president.name} вступает в должность президента государства ${country.name}. Правительство получает полный набор инструментов управления страной.`);
        pushNews(game, "Мир", "Дипломатический календарь открыт", `МИД начал работу с ${diplomacy.countries.length} странами и международными организациями.`);
        pushHistory(game);
        return game;
      }

      function pushNews(game, category, title, text, impact = {}) {
        game.news.unshift({ id: uid("news"), date: formatDate(game.date), category, title, text, impact });
        game.news = game.news.slice(0, 240);
      }

      function pushHistory(game) {
        const h = game.history;
        const income = calcIncome(game);
        const expenses = calcExpenses(game);
        h.date.push(formatDate(game.date));
        h.gdp.push(Number(game.economy.gdp.toFixed(2)));
        h.inflation.push(Number(game.economy.inflation.toFixed(2)));
        h.popularity.push(Number(game.politics.popularity.toFixed(2)));
        h.army.push(Number(calcArmyPower(game).toFixed(2)));
        h.population.push(Math.round(game.population.total));
        h.unemployment.push(Number(game.economy.unemployment.toFixed(2)));
        h.income.push(Number(income.toFixed(2)));
        h.expenses.push(Number(expenses.toFixed(2)));
        for (const key of Object.keys(h)) h[key] = h[key].slice(-420);
      }

      function calcIncome(game = state) {
        const e = game.economy;
        const t = e.taxes;
        const base = e.gdp * ((t.income * .19 + t.vat * .23 + t.corporate * .18 + t.property * .05 + t.export * .04) / 100);
        return base + e.exports * .035 + e.stateCompanies * 140;
      }

      function calcExpenses(game = state) {
        const e = game.economy;
        const spend = Object.values(e.spending).reduce((a, b) => a + b, 0) / 100;
        return e.gdp * spend * .23 + e.debt * (e.keyRate / 100) / 12 + e.pensions * game.population.total / 1000000 * .09;
      }

      function calcArmyPower(game = state) {
        const m = game.military;
        return (m.land / 10000) + m.air * .13 + m.navy * .42 + m.airDefense * .22 + m.strategic * 1.8 + m.cyber * .8 + m.special / 2600 + m.readiness * .75 + m.morale * .55;
      }

      function totalBuildings(key, game = state) {
        return game.regions.reduce((sum, r) => sum + (r.buildings[key] || 0), 0);
      }

