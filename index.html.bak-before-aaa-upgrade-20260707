      function advanceDate(d) {
        const days = [31, isLeap(d.year) ? 29 : 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31];
        d.day++;
        if (d.day > days[d.month - 1]) {
          d.day = 1;
          d.month++;
          if (d.month > 12) {
            d.month = 1;
            d.year++;
          }
        }
      }

      function isLeap(year) {
        return year % 4 === 0 && (year % 100 !== 0 || year % 400 === 0);
      }

      function simulateEconomy(game) {
        const e = game.economy;
        const pop = game.population;
        const infra = totalBuildingValue(game, ["roads","ports","airports","plants"]);
        const plants = totalBuildings("plants", game);
        const factories = totalBuildings("factories", game);
        const farms = totalBuildings("farms", game);
        const ports = totalBuildings("ports", game);
        const oil = totalBuildings("oil", game);
        const gas = totalBuildings("gas", game);
        const education = pop.education / 100;
        const taxLoad = (e.taxes.income + e.taxes.vat + e.taxes.corporate + e.taxes.export) / 100;
        const stability = (game.politics.popularity + 100 - game.politics.corruption + pop.happiness) / 300;
        const targetAnnualGrowth = clamp(
          e.growth
          + infra * .035
          + (education - .55) * 1.8
          + (stability - .5) * 2.5
          - Math.max(0, taxLoad - .38) * 3.5
          - Math.max(0, e.inflation - 4) * .18
          - game.military.wars.length * 2.5,
          -8,
          10
        );
        const growthDaily = targetAnnualGrowth / 100 / DAYS_PER_YEAR;
        e.gdp = Math.max(1000, e.gdp * (1 + growthDaily));
        const income = calcIncome(game) / 365;
        const expenses = calcExpenses(game) / 365;
        e.budget += income - expenses;
        if (e.budget < -e.gdp * .08) {
          e.debt += Math.abs(e.budget);
          e.budget = 0;
          e.inflation += .08;
          game.politics.popularity -= .04;
        }
        e.debt = Math.max(0, e.debt + Math.max(0, expenses - income) * .18 - Math.max(0, income - expenses) * .05);
        e.reserves = Math.max(0, e.reserves + (e.exports - e.imports) / DAYS_PER_YEAR * .12 - Math.max(0, e.emission) * .006);
        const ratePressure = clamp((e.inflation - e.keyRate) * .00045, -.003, .003);
        const welfarePressure = Math.max(0, e.spending.welfare - 24) * .00022;
        e.inflation = clamp(e.inflation + (e.emission * .000002) + ratePressure + welfarePressure - plants * .00012, -2, 80);
        e.unemployment = clamp(
          e.unemployment
          - e.growth * .00055
          + Math.max(0, e.taxes.corporate - 18) * .00028
          - factories * .00022
          - farms * .0001,
          1,
          45
        );
        e.avgSalary = Math.max(e.minSalary, e.avgSalary * (1 + growthDaily * .55 + (e.inflation / 100) / DAYS_PER_YEAR * .6));
        e.exchangeRate = clamp(e.exchangeRate * (1 + (e.inflation - e.keyRate) / 52000 - (e.reserves / Math.max(1, e.gdp)) * .00018), 0.1, 5000);
        e.exports = Math.max(100, e.exports * (1 + growthDaily * .35 + ports * .00002 + oil * .000025 + gas * .000022));
        e.imports = Math.max(100, e.imports * (1 + pop.life * .0000007 + e.growth * .000003 - farms * .000012));
        e.investments = Math.max(0, e.investments * (1 + growthDaily * .8 + (100 - game.politics.corruption) * .000001 + (e.keyRate < 8 ? .00008 : -.000045)));
        e.smallBusiness = clamp(e.smallBusiness + (e.taxes.corporate < 18 ? .002 : -.001) + (e.unemployment < 7 ? .0008 : -.0008), 0, 100);
        e.bankruptcies = clamp(e.bankruptcies + (e.keyRate > 13 ? .002 : -.001) + (e.growth < 0 ? .004 : -.0008), 0, 30);
        e.growth = clamp(targetAnnualGrowth * .008 + e.growth * .992, -12, 12);
        e.stockIndex = Math.max(100, e.stockIndex * (1 + growthDaily * 3 + (game.politics.popularity - 50) * .00001 - game.military.wars.length * .001));
        e.companies.forEach(c => {
          c.trend = clamp(c.trend * .7 + e.growth * .08 + rnd(-.45, .45) - e.keyRate * .01, -8, 8);
          c.value = Math.max(100, c.value * (1 + c.trend / 3650));
        });
        e.emission *= .995;
      }

      function totalBuildingValue(game, keys) {
        return game.regions.reduce((sum, r) => sum + keys.reduce((a, k) => a + (r.buildings[k] || 0), 0), 0);
      }

      function simulatePolitics(game) {
        const p = game.politics;
        const e = game.economy;
        const pop = game.population;
        const pressure = e.inflation * .09 + e.unemployment * .16 + pop.poverty * .1 + p.corruption * .07 - pop.happiness * .06;
        const aiAdminRelief = game.tech.nodes.find(n => n.id === "ai_admin")?.done ? .02 : 0;
        p.popularity = clamp(p.popularity + e.growth * .001 + (pop.happiness - 50) * .0007 - pressure * .006 + rnd(-.018, .018), 0, 100);
        p.protests = clamp(p.protests + pressure * .004 + p.opposition * .0011 - p.popularity * .0012 + rnd(-.015, .015), 0, 100);
        p.strikes = clamp(p.strikes + e.unemployment * .001 + e.inflation * .0007 - p.popularity * .00075, 0, 100);
        p.opposition = clamp(p.opposition + (50 - p.popularity) * .0008 + p.corruption * .00035, 0, 100);
        p.corruption = clamp(p.corruption + p.lobbyism * .00022 - aiAdminRelief - e.spending.security * .00025 + rnd(-.008, .01), 0, 100);
        p.coalition = clamp(p.coalition + (p.popularity - 50) * .0015 + rnd(-.025, .025), 0, 100);
        p.impeachmentRisk = clamp((p.protests * .22 + p.corruption * .12 + Math.max(0, 45 - p.coalition) * .42 + Math.max(0, 30 - p.popularity) * .5), 0, 100);
        p.electionInDays--;
        if (p.referendumCooldown > 0) p.referendumCooldown--;
        if (p.electionInDays <= 0) runElection(game);
        if (p.impeachmentRisk > 86 && Math.random() < .006) {
          p.popularity = clamp(p.popularity - 8, 0, 100);
          p.coalition = clamp(p.coalition - 12, 0, 100);
          pushNews(game, "Политика", "Процедура импичмента", "Оппозиция инициировала процедуру импичмента. Коалиция требует срочных уступок и публичного антикризисного плана.");
        }
      }

      function simulatePopulation(game) {
        const p = game.population;
        const e = game.economy;
        const dailyBirth = p.total * (p.birthRate / 1000) / 365;
        const dailyDeath = p.total * (p.deathRate / 1000) / 365;
        const migration = p.total * (p.migration / 100) / 365;
        p.total = Math.max(10000, p.total + dailyBirth - dailyDeath + migration);
        p.happiness = clamp(p.happiness + (game.politics.popularity - 50) * .0006 + e.growth * .0012 - e.inflation * .0008 - e.unemployment * .001 - p.crime * .0004 + e.spending.welfare * .0008, 0, 100);
        p.discontent = clamp(100 - p.happiness + e.unemployment * .22 + e.inflation * .18 + game.politics.protests * .2, 0, 100);
        p.crime = clamp(p.crime + p.poverty * .0007 + e.unemployment * .001 - e.spending.security * .0009 - totalBuildings("schools", game) * .00014, 0, 100);
        p.education = clamp(p.education + e.spending.education * .00025 + totalBuildings("universities", game) * .00045 + totalBuildings("schools", game) * .00016, 0, 100);
        p.life = clamp(p.life + e.spending.health * .00028 + totalBuildings("hospitals", game) * .00022 - p.crime * .00015 - e.inflation * .00012, 0, 100);
        p.poverty = clamp(p.poverty + e.unemployment * .001 + e.inflation * .00045 - e.spending.welfare * .00055 - e.growth * .0022, 0, 80);
        p.birthRate = clamp(p.birthRate + (p.happiness - 50) * .00015 - p.poverty * .00008, 3, 28);
        p.deathRate = clamp(p.deathRate - p.life * .000012 + p.poverty * .000012, 3, 30);
      }

      function simulateTech(game) {
        const t = game.tech;
        const focus = t.nodes.find(n => n.id === t.focus && !n.done);
        t.points += (t.labs * .14 + game.economy.spending.science * .025 + totalBuildings("universities", game) * .04) * (game.population.education / 80) * .45;
        if (focus) {
          const locked = focus.requires.some(id => !t.nodes.find(x => x.id === id)?.done);
          if (!locked) {
            focus.progress += (t.labs * .09 + game.economy.spending.science * .018 + game.military.research * .004) * .55;
            if (focus.progress >= focus.cost) completeTech(game, focus);
          }
        }
      }

      function completeTech(game, node) {
        node.done = true;
        node.progress = node.cost;
        if (node.id === "ai_admin") game.politics.corruption = clamp(game.politics.corruption - 4, 0, 100);
        if (node.id === "energy_grid") game.economy.inflation = clamp(game.economy.inflation - .8, -2, 80);
        if (node.id === "bio_medicine") game.population.life = clamp(game.population.life + 4, 0, 100);
        if (node.id === "smart_armor") game.military.readiness = clamp(game.military.readiness + 5, 0, 100);
        if (node.id === "drone_swarms") game.military.cyber = clamp(game.military.cyber + 8, 0, 100);
        pushNews(game, "Открытия", "Технологический прорыв", `Завершено исследование: ${node.name}. ${node.desc}.`);
      }

      function simulateRegions(game) {
        for (const r of game.regions) {
          const infra = Object.entries(r.buildings).reduce((sum, [k, v]) => sum + v * (k === "cities" ? 3 : 1), 0);
          r.wealth = clamp(r.wealth + game.economy.growth * .0015 + infra * .00025 - r.pollution * .00018, 0, 100);
          r.loyalty = clamp(r.loyalty + (game.politics.popularity - 50) * .0008 - game.politics.protests * .00035 + r.budget * .000002, 0, 100);
          r.security = clamp(r.security + game.economy.spending.security * .00035 + r.buildings.bases * .002 - game.population.crime * .00028, 0, 100);
          r.pollution = clamp(r.pollution + r.buildings.factories * .001 + r.buildings.oil * .002 + r.buildings.gas * .001 - r.buildings.plants * .0005, 0, 100);
          r.population = Math.max(1000, r.population + r.population * ((game.population.birthRate - game.population.deathRate) / 1000) / 365 + r.buildings.cities * 5);
        }
      }

      function simulateDiplomacy(game) {
        const e = game.economy;
        for (const c of game.diplomacy.countries) {
          const ai = c.aiMood;
          if (ai === "торговый") c.trade *= 1 + rnd(-.0002, .0009);
          if (ai === "силовой") c.military = clamp(c.military + rnd(-.01, .04), 0, 100);
          if (ai === "реформистский") c.stability = clamp(c.stability + rnd(-.02, .04), 0, 100);
          c.relations = clamp(c.relations + rnd(-.045, .045) + (c.alliance ? .012 : 0) - (c.sanctions ? .035 : 0) - (c.war ? .18 : 0), 0, 100);
          c.gdp = Math.max(100, c.gdp * (1 + rnd(-.00008, .00016)));
          if (!c.war && c.relations < 8 && c.military > 70 && Math.random() < .0005) {
            c.war = true;
            game.military.wars.push({ id: uid("war"), enemy: c.name, intensity: Math.round(rnd(24, 58)), fatigue: 0 });
            pushNews(game, "Мир", "Военный конфликт", `${c.name} начала вооружённую фазу конфликта. Генштаб переводит силы в режим высокой готовности.`);
          }
        }
        const tradeBonus = game.diplomacy.countries.reduce((sum, c) => sum + (c.relations > 60 && !c.sanctions && !c.embargo ? c.trade : 0), 0) * .000001;
        e.exports *= 1 + tradeBonus / 365;
      }

      function simulateMilitary(game) {
        const m = game.military;
        m.readiness = clamp(m.readiness + m.budget * .00025 + m.industry * .00016 - m.wars.length * .009, 0, 100);
        m.morale = clamp(m.morale + (game.politics.popularity - 50) * .00035 - m.wars.length * .018 - m.mobilized * .0000004, 0, 100);
        m.industry = clamp(m.industry + game.economy.spending.defense * .00025 + totalBuildings("factories", game) * .00018, 0, 100);
        for (const w of m.wars) {
          w.fatigue = clamp(w.fatigue + w.intensity * .002, 0, 100);
          game.economy.budget -= w.intensity * .9;
          game.politics.protests = clamp(game.politics.protests + w.fatigue * .0009, 0, 100);
          if (w.fatigue > 85 && Math.random() < .004) {
            pushNews(game, "Армия", "Перемирие", `Стороны конфликта с ${w.enemy} согласовали режим прекращения огня.`);
            const c = game.diplomacy.countries.find(x => x.name === w.enemy);
            if (c) c.war = false;
            m.wars = m.wars.filter(x => x.id !== w.id);
          }
        }
      }

      function generateDailyNews(game) {
        const category = pick(newsCategories);
        const region = pick(game.regions);
        const country = pick(game.diplomacy.countries);
        const templates = {
          "Экономика": [`Биржевой индекс закрылся на отметке ${Math.round(game.economy.stockIndex)} пунктов.`, `Бизнес просит пересмотреть ставку ${pct(game.economy.keyRate)}.`],
          "Политика": [`Коалиция удерживает ${pct(game.politics.coalition,0)} голосов в парламенте.`, `Оппозиция требует слушаний по расходам бюджета.`],
          "Армия": [`${game.country.armyName} провели учения в регионе ${region.name}.`, `Военная промышленность оценивается в ${pct(game.military.industry,0)} потенциала.`],
          "Мир": [`${country.name} меняет тон переговоров: отношения ${pct(country.relations,0)}.`, `Дипломаты готовят саммит по торговле и визовому режиму.`],
          "Катастрофы": [`В ${region.name} проверяют готовность служб к паводкам и пожарам.`, `МЧС обновляет карту рисков по инфраструктуре.`],
          "Эпидемии": [`Минздрав усиливает мониторинг сезонных заболеваний.`, `Больницы получают дополнительные резервы лекарств.`],
          "Скандалы": [`Журналисты изучают контракты региональной администрации.`, `Антикоррупционная комиссия открыла внеплановую проверку.`],
          "Выборы": [`До очередных выборов осталось ${game.politics.electionInDays} дней.`, `Партии обновляют региональные штабы.`],
          "Аварии": [`Транспортные службы ${region.name} устраняют сбой на магистрали.`, `Энергетики докладывают о стабильной работе сетей.`],
          "Безопасность": [`${game.country.intelligenceName} предупреждает о росте кибератак.`, `Полиция отчиталась о раскрытии крупной схемы.`],
          "Открытия": [`Учёные представили результаты по направлению "${game.tech.nodes.find(n => n.id === game.tech.focus)?.name || "приоритетная технология"}".`, `Университеты получили новые гранты.`]
        };
        pushNews(game, category, newsTitle(category), pick(templates[category] || templates["Мир"]));
      }

      function newsTitle(category) {
        return ({
          "Экономика": "Рынки реагируют на решения правительства",
          "Политика": "Парламентская повестка меняется",
          "Армия": "Генштаб докладывает президенту",
          "Мир": "Дипломатическая сводка",
          "Катастрофы": "Региональные риски",
          "Эпидемии": "Санитарный мониторинг",
          "Скандалы": "Проверка контрактов",
          "Выборы": "Предвыборная динамика",
          "Аварии": "Инфраструктурный инцидент",
          "Безопасность": "Сводка безопасности",
          "Открытия": "Научная новость"
        })[category] || "Сводка дня";
      }

      function triggerRandomEvent(game) {
        triggerEvent(pick(["natural","economic","scandal","epidemic","unrest","terror","discovery"]), game);
      }

      function triggerEvent(type, game = state) {
        const region = pick(game.regions);
        const e = game.economy;
        const p = game.politics;
        const pop = game.population;
        const data = {
          natural: ["Катастрофы", "Стихийное бедствие", `В регионе ${region.name} произошла чрезвычайная ситуация. Бюджет выделяет средства на восстановление.`, () => { e.budget -= 420; region.loyalty -= 2; pop.happiness -= 1.2; }],
          economic: ["Экономика", "Финансовый кризис", "Кредитный рынок сжимается, растёт риск банкротств и давления на валюту.", () => { e.stockIndex *= .94; e.bankruptcies += 1.1; e.exchangeRate *= 1.025; p.popularity -= 1.4; }],
          scandal: ["Скандалы", "Коррупционный скандал", `Прокуратура проверяет закупки в регионе ${region.name}.`, () => { p.corruption += 2.2; p.popularity -= 1.8; p.protests += 1; }],
          epidemic: ["Эпидемии", "Очаг заболевания", "Минздрав вводит санитарные меры и мобилизует больницы.", () => { pop.happiness -= 1.5; pop.deathRate += .2; e.budget -= 310; }],
          unrest: ["Политика", "Митинги и забастовки", "Профсоюзы требуют повышения зарплат и снижения инфляции.", () => { p.protests += 3.4; p.strikes += 2.6; e.growth -= .18; }],
          terror: ["Безопасность", "Теракт предотвращён частично", `${game.country.intelligenceName} задержала часть группы, но общество требует ответов.`, () => { pop.happiness -= 2; pop.crime += 1.6; p.popularity -= .9; game.military.readiness += 1; }],
          discovery: ["Открытия", "Научный прорыв", "Исследовательский консорциум представил технологию с экспортным потенциалом.", () => { game.tech.points += 55; e.investments += 650; p.popularity += 1.2; }]
        }[type];
        data[3]();
        pushNews(game, data[0], data[1], data[2]);
      }

      function buildInRegion(key) {
        const region = state.regions.find(r => r.id === selectedRegionId);
        const spec = buildingTypes.find(b => b[0] === key);
        if (!region || !spec) return;
        const cost = spec[2];
        if (state.economy.budget < cost) {
          notify("Недостаточно бюджета.");
          return;
        }
        state.economy.budget -= cost;
        region.buildings[key] = (region.buildings[key] || 0) + 1;
        region.budget += cost * .18;
        const effects = spec[3];
        if (effects.gdp) state.economy.gdp += effects.gdp * 100;
        if (effects.population) {
          region.population += effects.population;
          state.population.total += effects.population;
        }
        if (effects.happiness) state.population.happiness = clamp(state.population.happiness + effects.happiness, 0, 100);
        if (effects.education) state.population.education = clamp(state.population.education + effects.education, 0, 100);
        if (effects.research) state.tech.points += effects.research * 10;
        if (effects.exports) state.economy.exports += effects.exports * 1000;
        if (effects.imports) state.economy.imports += effects.imports * 600;
        if (effects.inflation) state.economy.inflation = clamp(state.economy.inflation + effects.inflation, -2, 80);
        if (effects.unemployment) state.economy.unemployment = clamp(state.economy.unemployment + effects.unemployment, 1, 45);
        if (effects.army) state.military.readiness = clamp(state.military.readiness + effects.army, 0, 100);
        if (effects.security) region.security = clamp(region.security + effects.security, 0, 100);
        if (effects.pollution) region.pollution = clamp(region.pollution + effects.pollution, 0, 100);
        pushNews(state, "Экономика", "Инфраструктурный проект", `${spec[1]} построен в регионе ${region.name}. Проект уже отражён в бюджете и статистике.`);
      }

      function updateRegionField(el) {
        const r = state.regions.find(x => x.id === selectedRegionId);
        if (!r) return;
        const key = el.dataset.regionField;
        r[key] = el.type === "number" || el.type === "range" ? num(el.value) : el.value;
      }

      function finishRegion() {
        if (drawingPoints.length < 3) {
          notify("Для региона нужно минимум три точки на карте.");
          return;
        }
        const region = {
          id: uid("region"),
          name: `Новый регион ${state.regions.length + 1}`,
          color: `hsl(${Math.floor(rnd(0, 360))} 58% 52%)`,
          governor: "назначьте губернатора",
          budget: 1200,
          population: 400000,
          loyalty: 50,
          wealth: 42,
          security: 48,
          pollution: 18,
          points: drawingPoints.map(p => [Math.round(p[0]), Math.round(p[1])]),
          buildings: emptyBuildings()
        };
        state.regions.push(region);
        selectedRegionId = region.id;
        drawingPoints = [];
        drawMode = false;
        pushNews(state, "Политика", "Новый регион", `Административная карта обновлена: создан регион ${region.name}.`);
      }

      function policyAction(policy) {
        const e = state.economy, p = state.politics, pop = state.population;
        const actions = {
          stimulus: () => { e.budget -= 1800; e.growth += .7; e.unemployment -= .35; e.inflation += .25; pushNews(state, "Экономика", "Пакет стимулов", "Правительство запускает инвестиции в занятость, инфраструктуру и спрос."); },
          anticorruption: () => { e.budget -= 420; p.corruption -= 5; p.popularity += 1.3; p.lobbyism -= 2; pushNews(state, "Скандалы", "Антикоррупционный рейд", "Прокуратура и аудиторы проверяют крупные контракты."); },
          health: () => { e.budget -= 900; pop.life += 2; pop.happiness += 1.5; pop.deathRate -= .12; pushNews(state, "Политика", "Нацпроект медицины", "Больницы получают оборудование, кадры и цифровую систему маршрутизации."); },
          education: () => { e.budget -= 760; pop.education += 2.8; state.tech.points += 35; pushNews(state, "Открытия", "Образовательная реформа", "Школы и университеты получили новый стандарт финансирования."); },
          security: () => { e.budget -= 520; pop.crime -= 2.6; p.protests += .6; state.military.cyber += 1.5; pushNews(state, "Безопасность", "Усиление безопасности", "Полиция и спецслужбы получили дополнительные полномочия и ресурсы."); },
          summit: () => { e.budget -= 280; state.diplomacy.countries.slice(0, 20).forEach(c => c.relations = clamp(c.relations + rnd(.2, 1.2), 0, 100)); pushNews(state, "Мир", "Международный саммит", "Президент принял лидеров, инвесторов и руководителей организаций."); }
        };
        actions[policy]?.();
        normalizeCore();
      }

      function economyAction(type) {
        const e = state.economy;
        if (type === "emit") { e.emission += 1200; e.budget += 1200; e.inflation += .9; }
        if (type === "bonds") { e.budget += 3500; e.debt += 3900; e.keyRate += .15; }
        if (type === "privatize") { e.budget += 2600; e.stateCompanies = Math.max(0, e.stateCompanies - 1); e.smallBusiness += 1.2; state.politics.lobbyism += .8; }
        if (type === "nationalize") { e.budget -= 2200; e.stateCompanies += 1; e.corporations = Math.max(0, e.corporations - 1); state.politics.popularity += .8; }
        if (type === "supportSmall") { e.budget -= 700; e.smallBusiness += 3; e.unemployment -= .25; }
        if (type === "bailout") { e.budget -= 1500; e.bankruptcies -= 1.2; e.stockIndex *= 1.018; state.politics.popularity -= .4; }
        normalizeCore();
        pushNews(state, "Экономика", "Решение экономического блока", "Параметры бюджета, рынка и бизнеса обновлены решением правительства.");
      }

      function politicsAction(type) {
        const p = state.politics;
        if (type === "law") {
          const law = { name: pick(["Закон о промышленной политике","Закон о цифровом государстве","Закон о местном самоуправлении","Закон о прозрачных закупках"]), effect: pick(["ускоряет инвестиции","усиливает контроль расходов","повышает доверие граждан","меняет баланс центра и регионов"]), support: Math.round(rnd(43, 82)) };
          p.laws.unshift(law);
          p.coalition += law.support > 55 ? 1.3 : -1;
        }
        if (type === "decree") {
          p.decrees.unshift({ name: `Указ №${p.decrees.length + 1}`, date: formatDate(state.date), effect: "оперативное решение президента" });
          p.popularity += .7;
          p.opposition += .3;
        }
        if (type === "referendum") {
          if (p.referendumCooldown > 0) return notify("Референдум можно провести позже.");
          p.referendumCooldown = 365;
          const win = p.popularity + rnd(-18, 18) > 50;
          p.popularity += win ? 4 : -6;
          p.coalition += win ? 3 : -4;
          pushNews(state, "Выборы", win ? "Референдум выигран" : "Референдум проигран", win ? "Большинство граждан поддержало инициативу президента." : "Избиратели отвергли инициативу, оппозиция усилилась.");
        }
        if (type === "election") runElection(state, true);
        if (type === "amend") { p.constitution.rights = clamp(p.constitution.rights + rnd(-3, 5), 0, 100); p.constitution.courtIndependence = clamp(p.constitution.courtIndependence + rnd(-2, 4), 0, 100); p.coalition -= 2; }
        if (type === "coalition") { p.coalition += rnd(3, 8); p.lobbyism += 1.5; p.popularity += .6; }
        normalizeCore();
        pushNews(state, "Политика", "Политическое решение", "Баланс партий, коалиции и общественной поддержки изменился.");
      }

      function runElection(game, early = false) {
        const p = game.politics;
        const result = clamp(p.popularity + game.economy.growth * 2 - p.corruption * .12 - p.protests * .2 + rnd(-12, 12), 0, 100);
        const won = result >= 45;
        p.electionInDays = 1825;
        p.popularity = clamp(result + (won ? 4 : -6), 0, 100);
        p.coalition = clamp(result + rnd(-8, 10), 0, 100);
        p.opposition = clamp(100 - result + rnd(-7, 7), 0, 100);
        p.parties[0].support = clamp(result, 5, 70);
        p.parties[0].seats = Math.round(p.parliamentSeats * p.parties[0].support / 100);
        pushNews(game, "Выборы", won ? "Президентская партия побеждает" : "Правящая партия теряет большинство", `${early ? "Досрочные выборы" : "Очередные выборы"} завершены с результатом ${pct(result,0)}.`);
      }

      function replaceMinister(index) {
        const names = ["Наталья Руднева","Максим Фомин","Сергей Вальд","Диана Яровая","Артур Ланской","Кира Светлова","Михаил Климов","Инга Ларина"];
        const m = state.politics.ministers[index];
        if (!m) return;
        m.name = pick(names);
        m.skill = Math.round(rnd(50, 88));
        m.loyalty = Math.round(rnd(45, 86));
        state.politics.popularity -= .4;
        pushNews(state, "Политика", "Кадровое решение", `${m.post}: назначен новый руководитель ${m.name}.`);
      }

      function diplomacyAction(type) {
        const c = state.diplomacy.countries.find(x => x.id === selectedCountryId);
        if (!c) return;
        const e = state.economy;
        if (type === "relations") { e.budget -= 90; c.relations += rnd(4, 10); c.embassy = true; }
        if (type === "trade") { e.budget -= 160; c.trade += rnd(600, 2200); c.treaties.push("торговый контракт"); c.relations += 3; }
        if (type === "alliance") { if (c.relations < 60) return notify("Для союза нужны отношения выше 60%."); c.alliance = true; c.treaties.push("союз"); c.relations += 5; }
        if (type === "sanctions") { c.sanctions = !c.sanctions; c.relations += c.sanctions ? -12 : 6; e.exports -= c.sanctions ? c.trade * .04 : -c.trade * .02; }
        if (type === "embargo") { c.embargo = !c.embargo; c.relations += c.embargo ? -16 : 5; c.trade *= c.embargo ? .62 : 1.18; }
        if (type === "milAid") { e.budget -= 540; c.relations += 8; c.military += 2; c.aid += 540; }
        if (type === "humanAid") { e.budget -= 220; c.relations += 6; c.stability += 3; c.aid += 220; }
        if (type === "spy") { e.budget -= 120; c.spy += rnd(4, 10); c.relations -= rnd(0, 2); state.military.cyber += .4; }
        if (type === "visa") { c.visa = c.visa === "свободный" ? "строгий" : c.visa === "строгий" ? "обычный" : "свободный"; c.relations += c.visa === "свободный" ? 3 : -2; }
        if (type === "war") { declareWar(c); }
        if (type === "peace") { c.war = false; c.relations += 8; state.military.wars = state.military.wars.filter(w => w.enemy !== c.name); }
        c.relations = clamp(c.relations, 0, 100);
        c.military = clamp(c.military, 0, 100);
        c.stability = clamp(c.stability, 0, 100);
        pushNews(state, "Мир", "Дипломатическое решение", `Отношения с ${c.name} теперь ${pct(c.relations,0)}. Статус: ${stripHtml(countryStatus(c))}.`);
      }

      function stripHtml(html) {
        const div = document.createElement("div");
        div.innerHTML = html;
        return div.textContent || "";
      }

      function declareWar(c) {
        if (c.war) return;
        c.war = true;
        c.relations = Math.min(c.relations, 2);
        state.military.wars.push({ id: uid("war"), enemy: c.name, intensity: Math.round(rnd(32, 72)), fatigue: 0 });
        state.politics.popularity = clamp(state.politics.popularity - 4, 0, 100);
        state.economy.stockIndex *= .93;
      }

      function createOrganization() {
        const name = document.getElementById("newOrgName")?.value.trim();
        const purpose = document.getElementById("newOrgPurpose")?.value.trim();
        if (!name) return notify("Введите название организации.");
        state.diplomacy.organizations.push({ id: uid("org"), name, purpose: purpose || "координация политики", members: 1, influence: 24, custom: true });
        pushNews(state, "Мир", "Создана международная организация", `${state.country.name} объявляет о запуске организации "${name}".`);
      }

      function militaryAction(type) {
        const m = state.military, e = state.economy;
        if (type === "mobilize") { m.mobilized += 45000; m.land += 18000; m.readiness += 3; m.morale -= 2; e.budget -= 900; state.politics.protests += 1.5; }
        if (type === "contract") { m.land += 6500; m.special += 700; m.contractShare += 1.2; e.budget -= 620; }
        if (type === "draft") { m.conscription = !m.conscription; m.manpower += m.conscription ? 45000 : -30000; state.politics.popularity += m.conscription ? -1.5 : 1.2; }
        if (type === "industry") { m.industry += 4; m.air += 8; m.airDefense += 3; e.budget -= 1100; }
        if (type === "cyber") { m.cyber += 4; e.budget -= 260; }
        if (type === "operation") { m.operations.unshift({ id: uid("op"), name: pick(["Щит столицы","Северный дозор","Киберпериметр","Морской рубеж"]), type: pick(["учения","разведка","контртеррор","операция"]), date: formatDate(state.date), result: Math.round(rnd(48, 92)) }); m.readiness += 1.4; e.budget -= 180; }
        normalizeCore();
        pushNews(state, "Армия", "Решение Генштаба", "Военные показатели, бюджет и общественная реакция обновлены.");
      }

      function warOperation(id) {
        const w = state.military.wars.find(x => x.id === id);
        if (!w) return;
        const power = calcArmyPower();
        const success = clamp(power / 3 + state.military.readiness + rnd(-35, 35) - w.intensity, 0, 100);
        w.fatigue += 5;
        state.economy.budget -= 700;
        if (success > 62) {
          w.intensity = clamp(w.intensity - rnd(5, 14), 0, 100);
          state.military.morale += 2;
        } else {
          w.intensity = clamp(w.intensity + rnd(2, 8), 0, 100);
          state.military.morale -= 2;
          state.politics.popularity -= 1;
        }
        pushNews(state, "Армия", success > 62 ? "Успешная операция" : "Сложная операция", `На направлении ${w.enemy} результат операции оценивается в ${pct(success,0)}.`);
        if (w.intensity < 8) {
          const c = state.diplomacy.countries.find(x => x.name === w.enemy);
          if (c) c.war = false;
          state.military.wars = state.military.wars.filter(x => x.id !== id);
          pushNews(state, "Армия", "Капитуляция противника", `${w.enemy} принимает условия прекращения боевых действий.`);
        }
      }

      function techLab() {
        const cost = 900 + state.tech.labs * 180;
        if (state.economy.budget < cost) return notify("Недостаточно бюджета на лабораторию.");
        state.economy.budget -= cost;
        state.tech.labs++;
        state.tech.points += 15;
      }

      function techFund() {
        if (state.economy.budget < 420) return notify("Недостаточно бюджета.");
        state.economy.budget -= 420;
        state.tech.points += 90;
        state.population.education += .5;
      }

      function socialAction(type) {
        const p = state.population, e = state.economy;
        if (type === "family") { e.budget -= 500; p.birthRate += .3; p.happiness += 1.2; }
        if (type === "migration") { e.budget -= 240; p.migration += .08; p.discontent += .3; e.unemployment += .08; }
        if (type === "police") { e.budget -= 360; p.crime -= 2.5; state.politics.protests += .4; }
        if (type === "housing") { e.budget -= 720; p.poverty -= 1.4; p.happiness += 1.8; e.growth += .12; }
        if (type === "culture") { e.budget -= 180; p.happiness += 1.1; state.politics.popularity += .8; }
        normalizeCore();
        pushNews(state, "Политика", "Социальная политика", "Обновлены демография, уровень жизни и общественные настроения.");
      }

      function generateNews(category) {
        pushNews(state, category, newsTitle(category), `Экстренная сводка категории "${category}" сформирована пресс-службой на дату ${formatDate(state.date)}.`);
      }

      function addLaw() {
        state.politics.laws.unshift({ name: "Новый закон " + (state.politics.laws.length + 1), effect: "настраиваемый эффект через редактор", support: 50 });
      }

      function addParty() {
        state.politics.parties.push({ name: "Новая партия " + (state.politics.parties.length + 1), ideology: "центризм", seats: 0, support: 3, coalition: false });
        normalizePercentages();
      }

      function normalizePercentages() {
        const parties = state.politics.parties;
        const sum = parties.reduce((a, b) => a + num(b.support), 0) || 1;
        for (const p of parties) {
          p.support = p.support / sum * 100;
          p.seats = Math.round(state.politics.parliamentSeats * p.support / 100);
        }
        normalizeCore();
      }

      function normalizeCore() {
        const e = state.economy, p = state.politics, pop = state.population, m = state.military;
        e.inflation = clamp(e.inflation, -2, 80);
        e.unemployment = clamp(e.unemployment, 1, 45);
        e.smallBusiness = clamp(e.smallBusiness, 0, 100);
        e.bankruptcies = clamp(e.bankruptcies, 0, 40);
        p.popularity = clamp(p.popularity, 0, 100);
        p.corruption = clamp(p.corruption, 0, 100);
        p.lobbyism = clamp(p.lobbyism, 0, 100);
        p.protests = clamp(p.protests, 0, 100);
        p.strikes = clamp(p.strikes, 0, 100);
        p.coalition = clamp(p.coalition, 0, 100);
        p.opposition = clamp(p.opposition, 0, 100);
        pop.happiness = clamp(pop.happiness, 0, 100);
        pop.discontent = clamp(pop.discontent, 0, 100);
        pop.crime = clamp(pop.crime, 0, 100);
        pop.life = clamp(pop.life, 0, 100);
        pop.education = clamp(pop.education, 0, 100);
        pop.poverty = clamp(pop.poverty, 0, 80);
        m.readiness = clamp(m.readiness, 0, 100);
        m.morale = clamp(m.morale, 0, 100);
        m.cyber = clamp(m.cyber, 0, 100);
        m.industry = clamp(m.industry, 0, 100);
        m.research = clamp(m.research, 0, 100);
        m.contractShare = clamp(m.contractShare, 0, 100);
      }

      function setEditorPath(path, value, asNumber) {
        const final = asNumber ? num(value) : value;
        if (path.startsWith("selectedRegion.")) {
          const r = state.regions.find(x => x.id === selectedRegionId);
          if (r) r[path.split(".")[1]] = final;
          return;
        }
        if (path.startsWith("selectedCountry.")) {
          const c = state.diplomacy.countries.find(x => x.id === selectedCountryId);
          if (c) c[path.split(".")[1]] = final;
          return;
        }
        const parts = path.split(".");
        let obj = state;
        for (let i = 0; i < parts.length - 1; i++) obj = obj[parts[i]];
        obj[parts[parts.length - 1]] = final;
        normalizeCore();
      }

      function saveSlot(slot) {
        const slots = loadSlots();
        slots[slot] = JSON.parse(JSON.stringify(state));
        saveSlots(slots);
        notify(`Слот ${slot} сохранён.`);
      }

      function loadSlot(slot) {
        const slots = loadSlots();
        if (!slots[slot]) return notify("Слот пуст.");
        state = migrateState(slots[slot]);
        saveState();
        notify(`Слот ${slot} загружен.`);
      }

      function exportSave() {
        const blob = new Blob([JSON.stringify(state, null, 2)], { type: "application/json" });
        const a = document.createElement("a");
        a.href = URL.createObjectURL(blob);
        a.download = `${state.country.name.replace(/\s+/g, "_")}_save.json`;
        a.click();
        URL.revokeObjectURL(a.href);
      }

      function importSaveFile() {
        const file = importFile.files?.[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = () => {
          try {
            state = migrateState(JSON.parse(String(reader.result)));
            saveState();
            notify("Сохранение импортировано.");
            render();
          } catch {
            notify("Не удалось прочитать JSON.");
          }
        };
        reader.readAsText(file);
      }

      function copyJson() {
        const text = document.getElementById("saveJson")?.value || JSON.stringify(state);
        navigator.clipboard?.writeText(text).then(() => notify("JSON скопирован."), () => notify("Скопируйте текст вручную."));
      }

      function loadJsonText() {
        const text = document.getElementById("saveJson")?.value;
        try {
          state = migrateState(JSON.parse(text));
          saveState();
          notify("JSON загружен.");
        } catch {
          notify("Ошибка JSON.");
        }
      }

      function confirmNewGame() {
        modal = {
          title: "Новая игра",
          body: `<p class="subtle">Текущее автосохранение будет удалено. Слоты останутся доступны.</p><div class="actions"><button class="danger" data-action="really-new-game">Удалить автосохранение</button><button data-action="close-modal">Отмена</button></div>`
        };
        render();
        setTimeout(() => {
          document.querySelector("[data-action='really-new-game']")?.addEventListener("click", () => {
            localStorage.removeItem(STORAGE_KEY);
            state = null;
            modal = null;
            render();
          }, { once: true });
        });
      }

      document.addEventListener("click", event => {
        if (event.target.closest("[data-action='really-new-game']")) {
          localStorage.removeItem(STORAGE_KEY);
          state = null;
          modal = null;
          render();
        }
      });

      document.addEventListener("click", event => {
        const svg = event.target.closest("#countryMap");
        if (!svg || !drawMode || event.target.closest("[data-action='select-region']")) return;
        const pt = svg.createSVGPoint();
        pt.x = event.clientX;
        pt.y = event.clientY;
        const p = pt.matrixTransform(svg.getScreenCTM().inverse());
        drawingPoints.push([clamp(p.x, 0, 900), clamp(p.y, 0, 520)]);
        render();
      });

      init();
    })();
  </script>
</body>
</html>
