<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Президент: симулятор государства</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #0d1117;
      --bg-2: #111827;
      --panel: rgba(22, 29, 42, .92);
      --panel-2: rgba(32, 42, 60, .94);
      --panel-3: rgba(15, 23, 42, .74);
      --text: #f8fafc;
      --muted: #9aa6b2;
      --line: rgba(148, 163, 184, .22);
      --line-strong: rgba(226, 232, 240, .34);
      --accent: #21c7a8;
      --accent-2: #4fa3ff;
      --danger: #ff5c7a;
      --warn: #ffbf47;
      --ok: #55d66b;
      --violet: #b487ff;
      --shadow: 0 22px 60px rgba(0, 0, 0, .33);
      --radius: 8px;
      --sidebar: 248px;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    body.light {
      color-scheme: light;
      --bg: #f4f7fb;
      --bg-2: #e9eef5;
      --panel: rgba(255, 255, 255, .94);
      --panel-2: rgba(248, 250, 252, .98);
      --panel-3: rgba(237, 242, 247, .9);
      --text: #111827;
      --muted: #5d6674;
      --line: rgba(50, 65, 88, .16);
      --line-strong: rgba(50, 65, 88, .28);
      --shadow: 0 20px 50px rgba(41, 55, 80, .16);
    }

    * { box-sizing: border-box; }

    html, body {
      min-height: 100%;
      margin: 0;
      background:
        radial-gradient(circle at 16% 10%, rgba(33, 199, 168, .16), transparent 29rem),
        radial-gradient(circle at 85% 20%, rgba(79, 163, 255, .14), transparent 26rem),
        linear-gradient(135deg, var(--bg) 0%, var(--bg-2) 100%);
      color: var(--text);
    }

    button, input, select, textarea {
      font: inherit;
      color: inherit;
    }

    button {
      border: 1px solid var(--line);
      background: var(--panel-2);
      border-radius: var(--radius);
      padding: 9px 12px;
      min-height: 38px;
      cursor: pointer;
      transition: transform .16s ease, border-color .16s ease, background .16s ease, box-shadow .16s ease;
    }

    button:hover {
      transform: translateY(-1px);
      border-color: var(--line-strong);
      box-shadow: 0 8px 22px rgba(0, 0, 0, .18);
    }

    button.primary {
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: #06111a;
      border: 0;
      font-weight: 800;
    }

    button.danger {
      background: color-mix(in oklab, var(--danger) 22%, var(--panel-2));
      border-color: color-mix(in oklab, var(--danger) 45%, transparent);
    }

    button.ghost {
      background: transparent;
    }

    button.icon {
      width: 40px;
      min-width: 40px;
      padding: 0;
      display: inline-grid;
      place-items: center;
      font-weight: 900;
    }

    button.active,
    .pill.active {
      border-color: color-mix(in oklab, var(--accent) 70%, white 10%);
      background: color-mix(in oklab, var(--accent) 18%, var(--panel-2));
    }

    input, select, textarea {
      width: 100%;
      min-height: 38px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--panel-3);
      padding: 9px 10px;
      outline: none;
      transition: border-color .16s ease, background .16s ease, box-shadow .16s ease;
    }

    textarea {
      min-height: 98px;
      resize: vertical;
      line-height: 1.45;
    }

    input[type="range"] {
      padding: 0;
      min-height: 26px;
    }

    input[type="color"] {
      padding: 3px;
      height: 38px;
    }

    input:focus, select:focus, textarea:focus {
      border-color: var(--accent-2);
      box-shadow: 0 0 0 3px rgba(79, 163, 255, .16);
    }

    label {
      display: grid;
      gap: 6px;
      font-size: 12px;
      letter-spacing: .02em;
      color: var(--muted);
      text-transform: uppercase;
    }

    .shell {
      min-height: 100vh;
      display: grid;
      grid-template-columns: var(--sidebar) minmax(0, 1fr);
    }

    .sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      border-right: 1px solid var(--line);
      background: rgba(7, 12, 20, .62);
      backdrop-filter: blur(20px);
      padding: 18px 14px;
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 18px;
      z-index: 5;
    }

    body.light .sidebar { background: rgba(246, 249, 252, .72); }

    .brand {
      display: grid;
      grid-template-columns: 54px 1fr;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }

    .seal {
      width: 54px;
      height: 54px;
      border-radius: 50%;
      border: 1px solid var(--line-strong);
      display: grid;
      place-items: center;
      overflow: hidden;
      background: conic-gradient(from 160deg, var(--accent), var(--accent-2), var(--warn), var(--accent));
      box-shadow: inset 0 0 0 7px rgba(0, 0, 0, .18), 0 12px 32px rgba(0, 0, 0, .22);
    }

    .seal span {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: rgba(5, 10, 18, .68);
      color: white;
      font-weight: 900;
    }

    .brand h1 {
      margin: 0;
      font-size: 17px;
      line-height: 1.15;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .brand p {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 12px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .nav {
      display: grid;
      gap: 6px;
      align-content: start;
      overflow: auto;
      padding-right: 4px;
    }

    .nav button {
      min-height: 42px;
      display: grid;
      grid-template-columns: 30px 1fr auto;
      align-items: center;
      gap: 8px;
      text-align: left;
      border-color: transparent;
      background: transparent;
      color: var(--muted);
    }

    .nav button:hover,
    .nav button.active {
      color: var(--text);
      background: var(--panel-2);
      border-color: var(--line);
    }

    .nav .nav-icon {
      width: 30px;
      height: 30px;
      border-radius: 8px;
      display: grid;
      place-items: center;
      background: var(--panel-3);
      font-weight: 900;
    }

    .side-foot {
      display: grid;
      gap: 10px;
    }

    .mini-stat {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--panel);
      padding: 10px;
      display: grid;
      gap: 6px;
      font-size: 12px;
      color: var(--muted);
    }

    .mini-stat strong {
      color: var(--text);
      font-size: 20px;
      line-height: 1;
    }

    .main {
      min-width: 0;
      padding: 18px;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 4;
      display: grid;
      grid-template-columns: minmax(220px, 1fr) auto;
      align-items: center;
      gap: 14px;
      margin: -18px -18px 18px;
      padding: 14px 18px;
      border-bottom: 1px solid var(--line);
      background: color-mix(in oklab, var(--bg) 74%, transparent);
      backdrop-filter: blur(20px);
    }

    .top-title {
      min-width: 0;
      display: grid;
      gap: 2px;
    }

    .top-title h2 {
      margin: 0;
      font-size: clamp(20px, 3vw, 32px);
      line-height: 1.05;
    }

    .top-title p {
      margin: 0;
      color: var(--muted);
      font-size: 13px;
    }

    .top-actions {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 8px;
      flex-wrap: wrap;
    }

    .speedbar {
      display: inline-flex;
      gap: 4px;
      padding: 4px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--panel);
    }

    .speedbar button {
      min-height: 32px;
      padding: 5px 8px;
      border-color: transparent;
      background: transparent;
      box-shadow: none;
    }

    .speedbar button.active {
      background: var(--panel-2);
      border-color: var(--line);
    }

    .grid {
      display: grid;
      gap: 14px;
    }

    .grid.two { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .grid.three { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .grid.four { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .grid.split { grid-template-columns: minmax(0, 1.45fr) minmax(310px, .8fr); }
    .grid.wide { grid-template-columns: minmax(0, 1fr) minmax(360px, .42fr); }

    .panel {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--panel);
      box-shadow: var(--shadow);
      min-width: 0;
      overflow: hidden;
    }

    .panel.pad { padding: 14px; }

    .panel-head {
      padding: 13px 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      border-bottom: 1px solid var(--line);
      background: color-mix(in oklab, var(--panel-2) 78%, transparent);
    }

    .panel-head h3,
    .section-title {
      margin: 0;
      font-size: 15px;
      line-height: 1.2;
    }

    .panel-head small,
    .subtle {
      color: var(--muted);
      font-size: 12px;
    }

    .metric-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
      gap: 10px;
    }

    .metric {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 12px;
      background: var(--panel-3);
      display: grid;
      gap: 8px;
      min-height: 104px;
      position: relative;
      overflow: hidden;
    }

    .metric::after {
      content: "";
      position: absolute;
      inset: auto 0 0;
      height: 3px;
      background: linear-gradient(90deg, var(--accent), var(--accent-2));
      opacity: .74;
    }

    .metric .label {
      color: var(--muted);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: .03em;
    }

    .metric .value {
      font-size: clamp(22px, 2.4vw, 34px);
      font-weight: 850;
      letter-spacing: 0;
      line-height: 1;
    }

    .metric .delta {
      color: var(--muted);
      font-size: 12px;
    }

    .delta.good { color: var(--ok); }
    .delta.bad { color: var(--danger); }
    .delta.warn { color: var(--warn); }

    .kpi-strip {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 8px;
    }

    .kpi {
      padding: 9px 10px;
      border-radius: var(--radius);
      border: 1px solid var(--line);
      background: var(--panel-3);
      display: grid;
      gap: 4px;
    }

    .kpi span {
      color: var(--muted);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: .03em;
    }

    .kpi strong {
      font-size: 16px;
      line-height: 1.1;
    }

    .list {
      display: grid;
      gap: 8px;
    }

    .row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items: center;
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--panel-3);
      min-width: 0;
    }

    .row.compact {
      grid-template-columns: auto 1fr auto;
      padding: 8px;
    }

    .row strong,
    .row span {
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      min-height: 30px;
      padding: 5px 9px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--panel-3);
      color: var(--muted);
      font-size: 12px;
      white-space: nowrap;
    }

    .toolbar {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
      gap: 12px;
    }

    .form-grid.narrow {
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    }

    .form-grid.full label {
      min-width: 0;
    }

    .actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
    }

    .canvas-wrap {
      height: 260px;
      padding: 12px;
    }

    canvas {
      width: 100%;
      height: 100%;
      display: block;
    }

    .progress {
      height: 8px;
      border-radius: 999px;
      background: rgba(148, 163, 184, .18);
      overflow: hidden;
      border: 1px solid var(--line);
    }

    .progress i {
      display: block;
      height: 100%;
      width: var(--w, 0%);
      background: linear-gradient(90deg, var(--accent), var(--accent-2));
    }

    .setup {
      min-height: 100vh;
      padding: 26px;
      display: grid;
      place-items: center;
    }

    .setup-card {
      width: min(1180px, 100%);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--panel);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .setup-hero {
      padding: clamp(22px, 4vw, 42px);
      min-height: 230px;
      display: grid;
      align-content: end;
      gap: 12px;
      background:
        linear-gradient(90deg, rgba(3, 8, 16, .78), rgba(3, 8, 16, .34)),
        repeating-linear-gradient(130deg, rgba(255,255,255,.08), rgba(255,255,255,.08) 1px, transparent 1px, transparent 28px),
        radial-gradient(circle at 76% 30%, rgba(33, 199, 168, .42), transparent 18rem),
        linear-gradient(135deg, #0c1824, #1b2535 55%, #22314a);
    }

    body.light .setup-hero {
      background:
        linear-gradient(90deg, rgba(255,255,255,.88), rgba(255,255,255,.35)),
        repeating-linear-gradient(130deg, rgba(0,0,0,.06), rgba(0,0,0,.06) 1px, transparent 1px, transparent 28px),
        radial-gradient(circle at 76% 30%, rgba(33, 199, 168, .28), transparent 18rem),
        linear-gradient(135deg, #e9f0f5, #dce7ef 55%, #cbd9e6);
    }

    .setup-hero h1 {
      margin: 0;
      font-size: clamp(32px, 6vw, 64px);
      line-height: .96;
      max-width: 780px;
    }

    .setup-hero p {
      margin: 0;
      color: color-mix(in oklab, var(--text) 76%, var(--muted));
      max-width: 720px;
      font-size: 16px;
      line-height: 1.55;
    }

    .setup-body {
      padding: 18px;
      display: grid;
      gap: 14px;
    }

    .tabs-line {
      display: flex;
      gap: 8px;
      overflow: auto;
      padding-bottom: 2px;
    }

    .tabs-line button {
      white-space: nowrap;
      min-height: 34px;
      padding: 6px 10px;
    }

    .map-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 330px;
      gap: 14px;
    }

    .map-stage {
      min-height: 560px;
      position: relative;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      overflow: hidden;
      background:
        linear-gradient(135deg, rgba(79, 163, 255, .14), transparent 30%),
        linear-gradient(0deg, rgba(33, 199, 168, .08), transparent 40%),
        var(--panel-3);
    }

    .map-stage svg {
      width: 100%;
      height: 100%;
      min-height: 560px;
      display: block;
    }

    .map-grid-line {
      stroke: rgba(148, 163, 184, .12);
      stroke-width: 1;
    }

    .region-poly {
      cursor: pointer;
      stroke: rgba(255, 255, 255, .8);
      stroke-width: 2;
      transition: filter .2s ease, opacity .2s ease, stroke-width .2s ease;
    }

    .region-poly:hover,
    .region-poly.selected {
      filter: brightness(1.18) saturate(1.18);
      stroke-width: 4;
    }

    .map-label {
      fill: white;
      paint-order: stroke;
      stroke: rgba(0,0,0,.55);
      stroke-width: 4;
      font-size: 16px;
      font-weight: 800;
      pointer-events: none;
    }

    .build-marker {
      pointer-events: none;
      filter: drop-shadow(0 5px 9px rgba(0,0,0,.32));
    }

    .draw-point {
      fill: var(--warn);
      stroke: #111;
      stroke-width: 2;
    }

    .table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }

    .table th,
    .table td {
      border-bottom: 1px solid var(--line);
      padding: 9px 8px;
      text-align: left;
      vertical-align: middle;
    }

    .table th {
      color: var(--muted);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: .03em;
      background: var(--panel-3);
      position: sticky;
      top: 0;
    }

    .scroll {
      overflow: auto;
      max-height: 500px;
    }

    .news-feed {
      display: grid;
      gap: 9px;
      max-height: 640px;
      overflow: auto;
      padding-right: 4px;
    }

    .news-item {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--panel-3);
      padding: 11px;
      display: grid;
      gap: 7px;
    }

    .news-item header {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
    }

    .news-item strong {
      font-size: 14px;
    }

    .news-item p {
      margin: 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
    }

    .tech-tree {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 10px;
    }

    .tech-card {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--panel-3);
      padding: 12px;
      display: grid;
      gap: 9px;
      min-height: 168px;
    }

    .tech-card.done {
      border-color: color-mix(in oklab, var(--ok) 55%, transparent);
      background: color-mix(in oklab, var(--ok) 10%, var(--panel-3));
    }

    .tech-card.locked {
      opacity: .58;
    }

    .flag {
      width: 76px;
      height: 48px;
      border-radius: 5px;
      border: 1px solid var(--line-strong);
      overflow: hidden;
      box-shadow: 0 10px 22px rgba(0,0,0,.22);
      display: grid;
    }

    .portrait {
      width: 82px;
      height: 82px;
      border-radius: 8px;
      object-fit: cover;
      background: var(--panel-3);
      border: 1px solid var(--line);
    }

    .empty-portrait {
      width: 82px;
      height: 82px;
      border-radius: 8px;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: #07121c;
      font-weight: 900;
      font-size: 30px;
    }

    .toast {
      position: fixed;
      right: 18px;
      bottom: 18px;
      z-index: 30;
      display: grid;
      gap: 8px;
      max-width: 360px;
    }

    .toast div {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--panel);
      box-shadow: var(--shadow);
      padding: 12px;
      animation: slideIn .24s ease both;
    }

    .modal-backdrop {
      position: fixed;
      inset: 0;
      z-index: 20;
      display: grid;
      place-items: center;
      padding: 18px;
      background: rgba(0,0,0,.58);
      backdrop-filter: blur(12px);
    }

    .modal {
      width: min(820px, 100%);
      max-height: calc(100vh - 36px);
      overflow: auto;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--panel);
      box-shadow: var(--shadow);
    }

    .modal-body {
      padding: 14px;
      display: grid;
      gap: 12px;
    }

    .hidden { display: none !important; }

    @keyframes slideIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 1060px) {
      .shell {
        grid-template-columns: 1fr;
      }
      .sidebar {
        position: relative;
        height: auto;
        border-right: 0;
        border-bottom: 1px solid var(--line);
      }
      .nav {
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        overflow: visible;
      }
      .side-foot {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .topbar,
      .grid.split,
      .grid.wide,
      .map-layout {
        grid-template-columns: 1fr;
      }
      .top-actions {
        justify-content: flex-start;
      }
      .grid.two,
      .grid.three,
      .grid.four {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 620px) {
      .main, .setup {
        padding: 10px;
      }
      .topbar {
        margin: -10px -10px 10px;
        padding: 10px;
      }
      .setup-card {
        border-radius: 0;
      }
      .speedbar {
        width: 100%;
        overflow: auto;
      }
      .metric-grid {
        grid-template-columns: 1fr;
      }
      .map-stage,
      .map-stage svg {
        min-height: 420px;
      }
    }
  </style>
</head>
<body>
  <div id="app"></div>
  <div class="toast" id="toast"></div>
  <input class="hidden" id="importFile" type="file" accept="application/json" />
  <script>
    (() => {
      "use strict";

      const STORAGE_KEY = "aaa_president_sim_state_v4";
