      function startTimer() {
        if (timer) clearInterval(timer);
        timer = setInterval(() => {
          if (!state || !state.speed) return;
          for (let i = 0; i < state.speed; i++) tickDay(state);
          saveState();
          scheduleRender();
        }, DAY_MS);
      }

      function scheduleRender() {
        if (pendingRender) return;
        pendingRender = true;
        requestAnimationFrame(() => {
          pendingRender = false;
          render();
        });
      }

