          name,
          continent: continents[i % continents.length],
          ideology: ideologies[i % ideologies.length],
          relations: clamp(Math.round(rnd(22, 78) + (neighborSet.has(name) ? 12 : 0)), 0, 100),
          trade: Math.round(rnd(120, 9200)),
          gdp: Math.round(rnd(9000, 4900000)),
          population: Math.round(rnd(350000, 280000000)),
