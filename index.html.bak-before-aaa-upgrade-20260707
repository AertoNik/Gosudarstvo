      function clamp(value, min, max) {
        return Math.max(min, Math.min(max, value));
      }

      function rnd(min, max) {
        return min + Math.random() * (max - min);
      }

      function pick(list) {
        return list[Math.floor(Math.random() * list.length)];
      }

      function uid(prefix) {
        return prefix + "_" + Math.random().toString(36).slice(2, 9) + Date.now().toString(36).slice(-4);
      }

      function esc(value) {
        return String(value ?? "").replace(/[&<>"']/g, ch => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[ch]));
      }

      function num(value, fallback = 0) {
        const n = Number(value);
        return Number.isFinite(n) ? n : fallback;
      }

      function pct(value, digits = 1) {
        return `${Number(value).toFixed(digits)}%`;
      }

      function money(value, currency = state?.country?.currency || "кред.") {
        const n = Number(value);
        const abs = Math.abs(n);
        let text;
        if (abs >= 1000000) text = (n / 1000000).toFixed(2) + " трлн";
        else if (abs >= 1000) text = (n / 1000).toFixed(2) + " млрд";
        else text = n.toFixed(1) + " млн";
        return `${text} ${currency}`;
      }

      function compact(value) {
        const n = Number(value);
        const abs = Math.abs(n);
        if (abs >= 1000000000) return (n / 1000000000).toFixed(2) + " млрд";
        if (abs >= 1000000) return (n / 1000000).toFixed(2) + " млн";
        if (abs >= 1000) return (n / 1000).toFixed(1) + " тыс.";
        return String(Math.round(n));
      }

